# ==========================================
# Frontend Environment Variables
# ==========================================

# The base URL of the FastAPI backend.
# In local development, typically http://127.0.0.1:5000
# In production on Render, it will be your Render web service URL (e.g. https://your-app.onrender.com)
REACT_APP_API_URL=http://127.0.0.1:5000
